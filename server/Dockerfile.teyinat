FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends libreoffice \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY server ./server
COPY games ./games

ENV TEYINAT_SERVICE_PORT=3002
EXPOSE 3002

CMD ["node", "server/teyinat-service.js"]
