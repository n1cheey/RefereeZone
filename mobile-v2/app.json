{
  "expo": {
    "name": "RefZone Mobile",
    "slug": "refzone-mobile-v2",
    "version": "2.0.0",
    "orientation": "portrait",
    "scheme": "refzonemobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f141d"
    },
    "ios": {
      "bundleIdentifier": "com.refzone.mobile.v2",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.refzone.mobile.v2",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#4f141d"
      },
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "defaultChannel": "refzone-mobile-alerts"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#4f141d"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
